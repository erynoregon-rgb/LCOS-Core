{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToyRoutingDecision",
  "type": "object",
  "required": ["kind", "reason", "evidence", "kernel_id"],
  "properties": {
    "kind": {"enum": ["ACCEPT", "HOLD", "REJECT", "ESCALATE"]},
    "reason": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "kernel_id": {"type": ["string", "null"]}
  }
}

